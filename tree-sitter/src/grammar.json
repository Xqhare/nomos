              "value": "dep"
            },
            {
              "type": "STRING",
              "value": "="
            },
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "PATTERN",
              "value": "[^\"]+"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "dep"
            },
            {
              "type": "STRING",
              "value": "="
            },
            {
              "type": "PATTERN",
              "value": "[^\\s]+"
            },
            {
              "type": "STRING",
              "value": ":"
            },
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "PATTERN",
              "value": "[^\"]+"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
