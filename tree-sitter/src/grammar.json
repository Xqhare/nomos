{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "nomos",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "version"
          },
          {
            "type": "SYMBOL",
            "name": "task"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "ignored_line"
          },
          {
            "type": "SYMBOL",
            "name": "empty_line"
          }
        ]
      }
    },
    "version": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "<!--[\\s]+nomos:[\\s]+[0-9]+[\\s]+-->"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_eol"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "task": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "task_marker"
        },
        {
          "type": "SYMBOL",
          "name": "stat"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "prio"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "title"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "delimiter"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "dates"
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "description"
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_eol"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "task_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "-"
            },
            {
              "type": "PATTERN",
              "value": "[ \\t]*"
            },
            {
              "type": "STRING",
              "value": "["
            }
          ]
        }
      }
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment_marker"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "description"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_eol"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "comment_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "*"
            },
            {
              "type": "PATTERN",
              "value": "[ \\t]+"
            }
          ]
        }
      }
    },
    "delimiter": {
      "type": "STRING",
      "value": "::"
    },
    "stat": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "stat_char"
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "stat_char": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "b"
        },
        {
          "type": "STRING",
          "value": "B"
        },
        {
          "type": "STRING",
          "value": "c"
        },
        {
          "type": "STRING",
          "value": "C"
        },
        {
          "type": "STRING",
          "value": "d"
        },
        {
          "type": "STRING",
          "value": "D"
        },
        {
          "type": "STRING",
          "value": "x"
        },
        {
          "type": "STRING",
          "value": "X"
        },
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "STRING",
          "value": "/"
        }
      ]
    },
    "prio": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "\\([0-9a-zA-Z]\\)"
        }
      }
    },
    "title": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_title_word"
          },
          {
            "type": "PATTERN",
            "value": "[()]"
          },
          {
            "type": "STRING",
            "value": ":"
          }
        ]
      }
    },
    "_title_word": {
      "type": "PATTERN",
      "value": "[^:\\r\\n\\s()]+"
    },
    "description": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "kind_tag"
          },
          {
            "type": "SYMBOL",
            "name": "location_tag"
          },
          {
            "type": "SYMBOL",
            "name": "generic_tag"
          },
          {
            "type": "SYMBOL",
            "name": "dependency_tag"
          },
          {
            "type": "SYMBOL",
            "name": "kv_tag"
          },
          {
            "type": "SYMBOL",
            "name": "_text_word"
          }
        ]
      }
    },
    "kind_tag": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "\\+[^\\s]+"
        }
      }
    },
    "location_tag": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "@[^\\s]+"
        }
      }
    },
    "generic_tag": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "#[^\\s]+"
        }
      }
    },
    "dependency_tag": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "dep=\"[^\"\\r\\n]*\""
            },
            {
              "type": "PATTERN",
              "value": "dep=[^\\s:]+:\"[^\"\\r\\n]*\""
            },
            {
              "type": "PATTERN",
              "value": "dep=[^\\s]+"
            }
          ]
        }
      }
    },
    "kv_tag": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\s=]+=[^\\s\"]+"
            },
            {
              "type": "PATTERN",
              "value": "[^\\s=]+=\"[^\"\\r\\n]*\""
            }
          ]
        }
      }
    },
    "_text_word": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\s]+"
        }
      }
    },
    "dates": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "date"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "date"
                },
                {
                  "type": "SYMBOL",
                  "name": "date"
                }
              ]
            }
          ]
        }
      ]
    },
    "date": {
      "type": "PATTERN",
      "value": "\\d{4}-\\d{2}-\\d{2}"
    },
    "ignored_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "[^\\r\\n]+"
            }
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_eol"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "empty_line": {
      "type": "SYMBOL",
      "name": "_eol"
    },
    "_eol": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "\n"
        },
        {
          "type": "STRING",
          "value": "\r\n"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\f\\v]"
    }
  ],
  "conflicts": [
    [
      "version"
    ],
    [
      "task"
    ],
    [
      "comment"
    ],
    [
      "ignored_line"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}